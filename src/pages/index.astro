---
// 
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro'; 
import Applications from '../components/Applications.astro'; 
import Equipment from '../components/Equipment.astro';
import ContactBanner from '../components/ContactBanner.astro';

import { getCollection } from 'astro:content';
const todosLosProductos = await getCollection('productos');
---

<Layout title="Gravocom">
    <Hero /> 
    <main>
      <TrustBar /> 
      <Applications />
      <Equipment />
      <ContactBanner />
  </main>
</Layout>

<style>
  .section-title { text-align: center; margin-top: 4rem; }
  .line { height: 4px; width: 50px; background: #ff4757; margin: 10px auto; border-radius: 2px; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
    padding: 2rem 5%;
  }
  .section-title { text-align: center; margin-top: 4rem; }
  .line { height: 4px; width: 50px; background: #ff4757; margin: 10px auto; border-radius: 2px; }
  header { text-align: center; padding: 4rem 1rem; background: #fff5f6; }
  h1 span { color: #ff4757; }
</style>