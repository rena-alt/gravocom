---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const productos = await getCollection('productos');

// Separamos por categorías para crear secciones visuales distintas
const equiposLaser = productos.filter(p => p.data.category === 'Marcado Láser');
const accesorios = productos.filter(p => p.data.category === 'Accesorios de Trazabilidad');
---

<Layout title="Catálogo Industrial | Gravocom">
  <main class="max-w-7xl mx-auto px-6 py-16">
    
    <header class="mb-20">
      <div class="flex items-center gap-4 mb-4">
        <span class="h-1 w-12 bg-orange-500"></span>
        <span class="text-orange-600 font-black uppercase tracking-[0.2em] text-sm">Portafolio de Soluciones</span>
      </div>
      <h1 class="text-5xl md:text-7xl font-black text-slate-900 mb-6 uppercase tracking-tighter">
        Equipos y <span class="text-orange-500">Trazabilidad</span>
      </h1>
      <p class="text-xl text-slate-600 max-w-3xl leading-relaxed border-l-4 border-slate-200 pl-6">
        Explora nuestra gama de tecnología láser de fibra y sistemas de lectura industrial diseñados para integrarse en procesos de alta exigencia.
      </p>
    </header>

    <section class="mb-24">
      <div class="flex justify-between items-end mb-10">
        <div>
          <h2 class="text-3xl font-black text-slate-900 uppercase">Sistemas de Marcado Láser</h2>
          <p class="text-slate-500 font-medium">Fuentes de Fibra Óptica Raycus / Max</p>
        </div>
        <a href="/productos/marcado-laser" class="hidden md:block text-sm font-bold text-orange-600 hover:text-orange-700 uppercase tracking-widest border-b-2 border-orange-500 pb-1 transition-all">
          Explorar Categoría →
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {equiposLaser.map(producto => (
          <a href={`/productos/${producto.slug}`} class="group relative bg-white border border-slate-200 p-8 rounded-2xl hover:border-orange-500 transition-all hover:shadow-2xl hover:shadow-orange-500/10">
            <div class="mb-6 aspect-video bg-slate-50 rounded-lg flex items-center justify-center overflow-hidden">
               <span class="text-slate-300 font-bold text-xs uppercase tracking-widest group-hover:scale-110 transition-transform">
                Preview {producto.data.title}
               </span>
            </div>
            <h3 class="text-2xl font-black text-slate-900 mb-2 group-hover:text-orange-500 transition-colors uppercase">
              {producto.data.title}
            </h3>
            <p class="text-slate-500 text-sm line-clamp-2 mb-6">
              {producto.data.description}
            </p>
            <div class="flex items-center text-xs font-black uppercase tracking-widest text-slate-900">
              Ficha Técnica
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2 group-hover:translate-x-2 transition-transform text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="bg-slate-950 rounded-[2.5rem] p-10 md:p-16 text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 w-1/3 h-full bg-orange-500/10 blur-[120px]"></div>
        
        <div class="relative z-10">
            <div class="mb-12">
                <h2 class="text-3xl font-black uppercase italic tracking-tighter">Lectura y Validación</h2>
                <p class="text-slate-400">Accesorios con protección IP54 para planta</p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                {accesorios.map(producto => (
                  <a href={`/productos/${producto.slug}`} class="group bg-white/5 border border-white/10 p-8 rounded-2xl hover:bg-white/10 hover:border-orange-500 transition-all">
                    <div class="flex justify-between items-start mb-4">
                        <h3 class="text-xl font-bold text-white group-hover:text-orange-500 transition-colors uppercase leading-tight">
                            {producto.data.title}
                        </h3>
                        <span class="bg-orange-500 text-white text-[10px] font-black px-2 py-1 rounded">IP54</span>
                    </div>
                    <p class="text-slate-400 text-sm mb-6">
                        {producto.data.description}
                    </p>
                    <span class="text-orange-500 text-xs font-bold uppercase tracking-widest group-hover:underline">
                        Detalles técnicos
                    </span>
                  </a>
                ))}
            </div>
        </div>
    </section>
  </main>
</Layout>