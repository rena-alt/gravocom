---
interface Props {
  title?: string;
  headers: string[];
  rows: string[][];
}

const { title, headers, rows } = Astro.props;
---

<div class="my-8 overflow-hidden rounded-xl border border-slate-200 shadow-sm">
  {title && (
    <div class="bg-slate-50 border-b border-slate-200 px-6 py-4">
      <h3 class="text-lg font-bold text-slate-800 tracking-tight">{title}</h3>
    </div>
  )}
  
  <div class="overflow-x-auto">
    <table class="w-full text-left text-sm border-collapse">
      <thead>
        <tr class="bg-slate-100/50 border-b border-slate-200">
          {headers.map((header: unknown) => (
            <th class="px-6 py-3 font-bold text-slate-700 uppercase tracking-wider">
              {header}
            </th>
          ))}
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        {rows.map((row: any[]) => (
          <tr class="hover:bg-blue-50/40 transition-colors">
            {row.map((cell: unknown) => (
              <td class="px-6 py-4 text-slate-600 font-medium">
                {cell}
              </td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>