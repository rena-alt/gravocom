---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <img src="/assets/gravocom-logo-white.svg" alt="Gravocom Logo" class="footer-logo" />
        <p>Expertos en marcado, asesoría y desarrollo de aplicaciones láser para la industria nacional.</p>
        <div class="social-icons">
          <a href="#" aria-label="LinkedIn">LN</a>
          <a href="#" aria-label="YouTube">YT</a>
        </div>
      </div>

      <div class="footer-nav">
        <h4>Soluciones</h4>
        <ul>
          <li><a href="/maquinaria">Marcado Fibra Óptica</a></li>
          <li><a href="/maquinaria">Limpieza Láser</a></li>
          <li><a href="/software">Software de Trazabilidad</a></li>
          <li><a href="/recursos-gratis">Descargas</a></li>
        </ul>
      </div>

      <div class="footer-contact">
        <h4>Contacto Directo</h4>
        <p><strong>Ventas:</strong> 5523007699</p>
        <p><strong>Email:</strong> cortiz@gravocom.com.mx</p>
        <p><strong>Ubicación:</strong> C. Centlapatl 178, San Martin Xochinahuac, Azcapotzalco, 02120 Ciudad de México, CDMX</p>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} Gravocom Laser Technology. Todos los derechos reservados.</p>
      <div class="legal">
        <a href="/privacidad">Aviso de Privacidad</a>
        <span>|</span>
        <a href="/seguridad">Seguridad Láser</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #0f172a;
    color: #94a3b8;
    padding: 4rem 5% 2rem;
    border-top: 4px solid #ff6b00; 
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 4rem;
    margin-bottom: 3rem;
  }

  .footer-logo {
    height: 40px;
    margin-bottom: 1.5rem;
    filter: brightness(0) invert(1);
  }

  .footer-brand p {
    line-height: 1.6;
    font-size: 0.95rem;
  }

  h4 {
    color: white;
    margin-bottom: 1.5rem;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  ul { list-style: none; padding: 0; }
  ul li { margin-bottom: 0.8rem; }
  
  ul a {
    color: #94a3b8;
    text-decoration: none;
    transition: 0.3s;
  }

  ul a:hover {
    color: #ff6b00;
    padding-left: 5px;
  }

  .footer-contact p {
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
  }

  .footer-contact strong { color: white; }

  .footer-bottom {
    border-top: 1px solid #1e293b;
    padding-top: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
  }

  .legal { display: flex; gap: 1rem; }
  .legal a { color: #64748b; text-decoration: none; }
  .legal a:hover { color: white; }

  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: 1fr; gap: 2.5rem; text-align: center; }
    .footer-bottom { flex-direction: column; gap: 1rem; text-align: center; }
    .footer-logo { margin: 0 auto 1.5rem; }
  }
</style>