---
const manager = {
  name: "Carlos Ortiz Medina",
  position: "Business Manager",
  phone: "5523007699",
  email: "cortiz@gravocom.com.mx"
};
---

<section class="my-16 bg-slate-950 rounded-2xl p-8 md:p-12 text-white relative overflow-hidden shadow-2xl border-l-8 border-l-orange-500">
  <div class="absolute top-0 right-0 w-80 h-80 bg-orange-500/5 rounded-full -mr-40 -mt-40 blur-3xl"></div>
  
  <div class="relative z-10 flex flex-col lg:flex-row items-center justify-between gap-10">
    <div class="text-center lg:text-left flex-1">
      <div class="inline-block bg-orange-500/20 text-orange-500 px-3 py-1 rounded-md text-xs font-black uppercase tracking-widest mb-4">
        Atención Directa
      </div>
      <h2 class="text-3xl md:text-4xl font-black text-white mb-4 leading-tight">
        Lleva tu línea de producción al <span class="text-orange-500 text-shadow-orange">siguiente nivel.</span>
      </h2>
      <p class="text-slate-400 text-lg max-w-lg">
        Consultoría especializada en integración láser y trazabilidad con <span class="text-slate-200 font-semibold">Carlos Ortiz.</span>
      </p>
    </div>

    <div class="bg-slate-900 border border-slate-800 p-8 rounded-xl w-full lg:w-auto min-w-[320px] shadow-inner">
      <div class="mb-6 pb-6 border-b border-slate-800">
        <p class="text-2xl font-black text-white">{manager.name}</p>
        <p class="text-orange-500 font-bold uppercase tracking-tighter text-sm">{manager.position}</p>
      </div>

      <div class="space-y-6">
        <a href={`tel:+52${manager.phone}`} class="flex items-center gap-4 group">
          <div class="bg-orange-500 group-hover:bg-orange-600 p-3 rounded-lg text-white transition-colors shadow-lg shadow-orange-500/20">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.948V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div>
            <p class="text-xs text-slate-500 uppercase font-bold">Llamada Directa</p>
            <span class="font-mono text-xl font-bold group-hover:text-orange-500 transition-colors tracking-tight">
                {manager.phone}
            </span>
          </div>
        </a>

        <a href={`mailto:${manager.email}`} class="flex items-center gap-4 group">
          <div class="bg-slate-800 group-hover:bg-slate-700 p-3 rounded-lg text-orange-500 transition-colors border border-slate-700">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <p class="text-xs text-slate-500 uppercase font-bold">Correo Corporativo</p>
            <span class="text-sm font-semibold group-hover:text-white transition-colors">{manager.email}</span>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
    .text-shadow-orange {
        text-shadow: 0 0 20px rgba(249, 115, 22, 0.3);
    }
</style>