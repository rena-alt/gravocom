---
const contactInfo = {
  manager: "Carlos Ortiz Medina",
  role: "Business Manager",
  phone: "5523007699",
  email: "cortiz@gravocom.com.mx"
};
---

<section class="contact-banner">
  <div class="container">
    <div class="contact-content">
      <span class="label">Asesoría Técnica Inmediata</span>
      <h2>¿Listo para optimizar tu <span>línea de producción?</span></h2>
      <p>
        Contacta directamente con nuestro Business Manager para recibir una 
        asesoría personalizada sobre trazabilidad y seguridad láser.
      </p>
      
      <div class="manager-card">
        <div class="manager-info">
          <strong>{contactInfo.manager}</strong>
          <span>{contactInfo.role}</span>
        </div>
        <div class="contact-methods">
          <a href={`https://wa.me/${contactInfo.phone}`} class="method">
             <span>📱</span> WhatsApp: {contactInfo.phone}
          </a>
          <a href={`mailto:${contactInfo.email}`} class="method">
             <span>✉️</span> {contactInfo.email}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-banner {
    padding: 5rem 5%;
    background: #0f172a;
    color: white;
    position: relative;
    overflow: hidden;
  }

  .contact-banner::after {
    content: '';
    position: absolute;
    top: -50%; right: -10%;
    width: 400px; height: 400px;
    background: rgba(255, 107, 0, 0.1);
    border-radius: 50%;
    filter: blur(80px);
  }

  .container { max-width: 1000px; margin: 0 auto; text-align: center; position: relative; z-index: 2; }

  .label { color: #ff6b00; font-weight: bold; text-transform: uppercase; letter-spacing: 2px; font-size: 0.8rem; }
  
  h2 { font-size: 2.5rem; margin: 1rem 0; }
  h2 span { color: #ff6b00; }
  
  p { color: #94a3b8; font-size: 1.1rem; margin-bottom: 3rem; }

  .manager-card {
    max-width: 295px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 107, 0, 0.3);
    padding: 2rem;
    border-radius: 15px;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    backdrop-filter: blur(10px);
  }

  .manager-info strong { display: block; font-size: 1.3rem; color: #fff; }
  .manager-info span { color: #ff6b00; font-weight: 500; }

  .contact-methods { display: flex; gap: 2rem; }
  
  .method {
    color: white;
    text-decoration: none;
    font-size: 1rem;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: 0.3s;
  }

  .method:hover { color: #ff6b00; }

  @media (max-width: 768px) {
    h2 { font-size: 1.8rem; }
    .contact-methods { flex-direction: column; gap: 1rem; }
    .manager-card { 
        width: 100%;
        max-width: 275px; 
    }
  }
</style>