---
// src/components/Applications.astro
const applications = [
  {
    title: "Industria Automotriz",
    description: "Marcado de números de serie (VIN), componentes de motor y trazabilidad de partes críticas.",
    icon: "🚗",
    tags: ["Acero", "Aluminio", "Plásticos"]
  },
  {
    title: "Herramental y Moldes",
    description: "Grabado profundo en moldes de inyección y personalización de herramientas de corte.",
    icon: "🛠️",
    tags: ["Acero Inox", "Titanio", "Cromo"]
  },
  {
    title: "Aerospace & Defensa",
    description: "Marcado de turbinas, fuselajes y componentes críticos con trazabilidad absoluta bajo estándares AS9100.",
    icon: "🚀", 
    tags: ["Inconel", "Aluminio 7075", "Titanio"]
  },
  {
    title: "Electrónica y Chips",
    description: "Micro-marcado en tarjetas de circuito (PCB) y carcasas de componentes electrónicos.",
    icon: "🔌",
    tags: ["Delrin", "ABS", "Silicio"]
  }
];
---

<section class="py-24 bg-white relative overflow-hidden">
  <div class="container mx-auto px-6">
    
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div class="max-w-2xl">
        <div class="flex items-center gap-2 mb-4">
          <span class="w-8 h-1 bg-orange-500"></span>
          <span class="text-orange-600 font-black uppercase tracking-widest text-xs">Versatilidad Técnica</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-black text-slate-900 uppercase tracking-tighter leading-none">
          Aplicaciones <br /> <span class="text-orange-500 italic">Multimaterial</span>
        </h2>
      </div>
      <p class="text-slate-500 font-medium max-w-sm border-l-2 border-slate-200 pl-4 text-sm">
        Nuestros sistemas MZF están optimizados para integrarse en cualquier flujo de trabajo industrial, garantizando legibilidad permanente.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {applications.map((app) => (
        <div class="group relative bg-slate-50 border border-slate-200 p-8 rounded-2xl hover:bg-slate-950 transition-all duration-500 overflow-hidden">
          
          <div class="absolute -bottom-4 -right-4 text-8xl opacity-5 group-hover:opacity-10 transition-opacity grayscale group-hover:grayscale-0">
            {app.icon}
          </div>

          <div class="relative z-10">
            <div class="w-12 h-12 bg-white shadow-sm rounded-xl flex items-center justify-center text-2xl mb-6 group-hover:bg-orange-500 group-hover:scale-110 transition-all duration-500">
              {app.icon}
            </div>
            
            <h3 class="text-xl font-black text-slate-900 group-hover:text-white mb-3 uppercase tracking-tight transition-colors">
              {app.title}
            </h3>
            
            <p class="text-slate-600 group-hover:text-slate-400 text-sm leading-relaxed mb-6 transition-colors">
              {app.description}
            </p>

            <div class="flex flex-wrap gap-2">
              {app.tags.map(tag => (
                <span class="text-[10px] font-bold px-2 py-1 rounded bg-slate-200 text-slate-600 group-hover:bg-orange-500/20 group-hover:text-orange-400 transition-colors uppercase tracking-widest">
                  {tag}
                </span>
              ))}
            </div>
          </div>

          <div class="absolute bottom-0 left-0 w-0 h-1 bg-orange-500 group-hover:w-full transition-all duration-500"></div>
        </div>
      ))}
    </div>

    <div class="mt-16 text-center">
      <p class="text-slate-400 text-sm font-bold uppercase tracking-[0.2em] mb-4">¿No ves tu industria aquí?</p>
      <a href="/contacto" class="inline-flex items-center gap-2 text-slate-900 font-black hover:text-orange-500 transition-colors uppercase text-sm border-b-2 border-slate-900 hover:border-orange-500 pb-1">
        Consultar viabilidad técnica
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>