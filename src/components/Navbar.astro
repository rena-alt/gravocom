---
// src/components/Navbar.astro
const phone = "525523007699"; 
const message = encodeURIComponent("Hola, me interesa recibir información y una cotización sobre los equipos de Gravocom.");
const whatsappUrl = `https://wa.me/${phone}?text=${message}`;

const navItems = [
  { name: "Maquinaria", href: "/productos" },
  { name: "Software", href: "/software" },
  { name: "Soporte", href: "/soporte" },
  { name: "Seguridad", href: "/seguridad-practicas", alert: true },
];
---

<nav class="sticky top-0 z-[1000] bg-slate-950 border-b border-white/5 h-[80px] flex items-center shadow-2xl">
  <div class="container mx-auto px-6 flex justify-between items-center">
    
    <div class="shrink-0">
      <a href="/" class="flex items-center group">
        <img src="/assets/gravocom-logo-white.svg" alt="Gravocom Logo" class="h-10 md:h-12 w-auto transition-transform group-hover:scale-105" />
      </a>
    </div>

    <div class="hidden lg:flex items-center gap-10">
      <ul class="flex items-center gap-8">
        {navItems.map(item => (
          <li>
            <a href={item.href} class="relative text-sm font-black uppercase tracking-widest text-slate-300 hover:text-orange-500 transition-colors flex items-center gap-2 group">
              {item.name}
              {item.alert && (
                <span class="flex h-2 w-2 relative">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-orange-500"></span>
                </span>
              )}
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-orange-500 transition-all group-hover:w-full"></span>
            </a>
          </li>
        ))}
      </ul>

      <a href={whatsappUrl} target="_blank" class="bg-orange-500 hover:bg-orange-600 text-white text-[10px] font-black uppercase tracking-[0.2em] px-6 py-3 rounded-lg transition-all shadow-lg shadow-orange-500/20 active:scale-95">
        Solicitar Cotización
      </a>
    </div>

    <button id="menu-btn" class="lg:hidden flex flex-col gap-1.5 p-2 group" aria-label="Abrir menú">
      <span class="w-6 h-0.5 bg-white group-hover:bg-orange-500 transition-all origin-center"></span>
      <span class="w-6 h-0.5 bg-white group-hover:bg-orange-500 transition-all opacity-100"></span>
      <span class="w-6 h-0.5 bg-white group-hover:bg-orange-500 transition-all origin-center"></span>
    </button>
  </div>

  <div id="mobile-menu" class="fixed inset-0 bg-slate-950/95 backdrop-blur-md translate-x-full transition-transform duration-500 lg:hidden flex flex-col items-center justify-center z-[1100]">
    <button id="close-btn" class="absolute top-8 right-8 text-white p-4 uppercase font-black tracking-widest text-xs">Cerrar [X]</button>
    
    <ul class="flex flex-col items-center gap-8 mb-12">
      {navItems.map(item => (
        <li>
          <a href={item.href} class="text-2xl font-black text-white uppercase tracking-tighter hover:text-orange-500 transition-colors flex items-center gap-3">
            {item.name}
            {item.alert && <span class="h-3 w-3 bg-orange-500 rounded-full"></span>}
          </a>
        </li>
      ))}
    </ul>

    <a href={whatsappUrl} target="_blank" class="w-[80%] max-w-sm bg-orange-500 text-white text-center font-black uppercase tracking-widest py-5 rounded-2xl shadow-xl shadow-orange-500/20">
      Cotizar ahora
    </a>
  </div>
</nav>

<script>
  const menuBtn = document.getElementById('menu-btn');
  const closeBtn = document.getElementById('close-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const bars = menuBtn?.querySelectorAll('span');

  const toggleMenu = () => {
    mobileMenu?.classList.toggle('translate-x-full');
    document.body.classList.toggle('overflow-hidden');
  };

  menuBtn?.addEventListener('click', toggleMenu);
  closeBtn?.addEventListener('click', toggleMenu);
</script>