---
// Reemplaza con tu ID de Formspree
const FORMSPREE_ID = "tu_id_aqui"; 
---

<section class="max-w-2xl mx-auto my-16 p-8 bg-white rounded-2xl border-t-4 border-t-orange-500 border-x border-b border-slate-200 shadow-xl">
  <div class="mb-8">
    <h2 class="text-2xl font-bold text-slate-900 flex items-center gap-2">
      <span class="w-2 h-8 bg-orange-500 rounded-full"></span>
      Solicitar Cotización Técnica
    </h2>
    <p class="text-slate-600 mt-2">
      Expertos en marcado y trazabilidad. Envíanos tus dudas y Carlos Ortiz te contactará a la brevedad.
    </p>
  </div>

  <form action={`https://formspree.io/f/${FORMSPREE_ID}`} method="POST" class="space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label for="full-name" class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-tight">Nombre Completo</label>
        <input type="text" name="name" id="full-name" required 
          class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none transition-all placeholder:text-slate-400" 
          placeholder="Ej. Ing. Alberto García">
      </div>
      <div>
        <label for="email" class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-tight">Email Corporativo</label>
        <input type="email" name="_replyto" id="email" required 
          class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none transition-all" 
          placeholder="contacto@empresa.com">
      </div>
    </div>

    <div>
      <label for="subject" class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-tight">Equipo de Interés</label>
      <select name="subject" id="subject" 
        class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-orange-500 bg-white outline-none cursor-pointer">
        <option value="Serie MZF 30W">Marcadora Láser MZF 30W</option>
        <option value="Serie MZF 50W">Marcadora Láser MZF 50W</option>
        <option value="Serie MZF 100W">Marcadora Láser MZF 100W</option>
        <option value="Lector Industrial IP54">Lector de Códigos 1D/2D IP54</option>
        <option value="Servicio Técnico">Servicio Técnico / Mantenimiento</option>
      </select>
    </div>

    <div>
      <label for="message" class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-tight">Requerimientos del Proyecto</label>
      <textarea id="message" name="message" rows="4" required 
        class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-orange-500 outline-none transition-all" 
        placeholder="Describa el material, profundidad de grabado o necesidades de integración..."></textarea>
    </div>

    <button type="submit" 
      class="w-full bg-orange-500 hover:bg-orange-600 text-white font-black py-4 px-6 rounded-lg transition-all shadow-lg shadow-orange-200 uppercase tracking-widest flex items-center justify-center gap-2 group">
      Enviar Mensaje
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
      </svg>
    </button>
  </form>
</section>