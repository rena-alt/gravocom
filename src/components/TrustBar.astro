---
// src/components/TrustBar.astro
const partners = [
  { name: "Raycus", detail: "Fiber Laser Source" },
  { name: "MaxPhotonics", detail: "High Power Laser" },
  { name: "IP54", detail: "Industrial Protection" },
  { name: "1D/2D", detail: "Traceability Expert" }
];
---

<div class="bg-slate-100 border-y border-slate-200 py-10 relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(#0f172a 1px, transparent 1px); background-size: 20px 20px;"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8 md:gap-4">
      
      <div class="flex flex-col items-center md:items-start shrink-0">
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-orange-500 mb-1">Tecnología de Grado</span>
        <h3 class="text-xl font-black text-slate-900 uppercase italic tracking-tighter">Industrial</h3>
      </div>

      <div class="h-px w-full md:h-12 md:w-px bg-slate-300"></div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12 w-full max-w-4xl">
        {partners.map(partner => (
          <div class="group flex flex-col items-center justify-center grayscale hover:grayscale-0 transition-all duration-500">
            <span class="text-lg font-black text-slate-800 group-hover:text-orange-600 transition-colors uppercase tracking-tight">
              {partner.name}
            </span>
            <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mt-1">
              {partner.detail}
            </span>
            <div class="w-0 group-hover:w-full h-0.5 bg-orange-500 mt-2 transition-all duration-300"></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>