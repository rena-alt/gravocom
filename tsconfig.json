{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["astro/client", "@netlify/edge-functions"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": [
    ".astro/types.d.ts", 
    "**/*", 
    "netlify/edge-functions/**/*.ts" 
  ],
  "exclude": ["dist"]
}